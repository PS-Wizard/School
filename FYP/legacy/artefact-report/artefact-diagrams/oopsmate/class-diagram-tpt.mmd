%%{init: {"theme": "base", "themeVariables": {"fontFamily": "JetBrains Mono", "fontSize": "10px"}, "htmlLabels": false, "flowchart": {"htmlLabels": false}}}%%
classDiagram
    class TTEntry {
        +key: u64
        +best_move: Move
        +score: i32
        +depth: u8
        +flag: u8
        +age: u8
    }

    class PackedTTEntry {
        -data: AtomicU64
        -signature: AtomicU64
    }

    class TTTable {
        -table: PackedEntryVec
        -mask: u64
        -generation: AtomicU8
        +new_mb(mb) TTTable
        +new_search()
        +probe(hash) TTEntryOpt
        +store(hash,mv,sc,d,flag)
        +clear()
        +hashfull() usize
    }

    class TTFlags {
        <<const>>
        EXACT=0
        LOWER_BOUND=1
        UPPER_BOUND=2
    }

    TTTable *-- PackedTTEntry
    TTTable --> TTEntry
    TTEntry --> Move
    TTEntry --> TTFlags
