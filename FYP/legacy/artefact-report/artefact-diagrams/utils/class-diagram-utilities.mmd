classDiagram
    direction TB
    class Algebraic {
        <<trait>>
        +place() u64
        +idx() usize
        +notation() String
        +single_notation() String
    }

    class StrImpl {
        +place(): parse sq list to bb
        +idx(): square to 0..63
    }

    class U64Impl {
        +notation(): bb to sq list
    }

    class UsizeImpl {
        +notation(): idx bits to alg
        +single_notation(): idx to sq
    }

    class PrintAsBoard {
        <<trait>>
        +print()
    }

    class U64BoardImpl {
        +print(): board with X and dot
    }

    Algebraic <|.. StrImpl
    Algebraic <|.. U64Impl
    Algebraic <|.. UsizeImpl
    PrintAsBoard <|.. U64BoardImpl
